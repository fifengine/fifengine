{
  "name": "fifengine",
  "version-string": "0.4.2",
  "description": "A portable, low latency, retained-mode GUI framework written in C++.",
  "homepage": "https://github.com/fifengine/fifengine",
  "license": "LGPL-2.1",
  "supports": "windows & x86 & x64",
  "dependencies": [
    {
      "name": "sdl2",
      "default-features": false,
      "platform": "linux",
      "features": [
        "x11"
      ]
    },
    {
      "name": "sdl2",
      "default-features": false,
      "platform": "windows",
      "features": []
    },
    "sdl2-ttf",
    "sdl2-image",
    "glew",
    "libogg",
    "libpng",
    "libvorbis",
    "openal-soft",
    "tinyxml2",
    "zlib",
    "catch2"
  ],
  "builtin-baseline": "62159a45e18f3a9ac0548628dcaf74fcb60c6ff9"
}
