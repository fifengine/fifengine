{
  "name": "fifengine",
  "version-string": "0.5.0",
  "description": "Fifengine is a multi-platform isometric game engine written in C++.",
  "homepage": "https://github.com/fifengine/fifengine",
  "license": "LGPL-2.1",
  "supports": "windows,linux,osx",
  "builtin-baseline": "c3867e714dd3a51c272826eea77267876517ed99",
  "dependencies": [
    {
      "name": "sdl2",
      "default-features": false,
      "platform": "linux",
      "features": [
        "x11"
      ]
    },
    {
      "name": "sdl2",
      "default-features": false,
      "platform": "windows",
      "features": []
    },
    "sdl2-ttf",
    "sdl2-image",
    "glew",
    "libogg",
    "libpng",
    "libvorbis",
    "openal-soft",
    "tinyxml2",
    "zlib",
    "catch2"
  ],
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json"
}
