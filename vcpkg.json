{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "fifengine",
  "version-string": "0.5.0",
  "description": "Fifengine is a multi-platform isometric game engine written in C++.",
  "homepage": "https://github.com/fifengine/fifengine",
  "license": "LGPL-2.1",
  "supports": "windows, (linux, osx)",
  "builtin-baseline": "f3e10653cc27d62a37a3763cd84b38bca07c6075",
  "dependencies": [
    "catch2",
    {
      "name": "spdlog",
      "default-features": false,
      "features": [
        "tz-offset"
      ]
    },
    "glew",
    "libogg",
    "libpng",
    "libvorbis",
    "openal-soft",
    {
      "name": "sdl3",
      "default-features": false,
      "features": [
        "x11"
      ],
      "platform": "linux"
    },
    {
      "name": "sdl3",
      "platform": "windows"
    },
    {
      "name": "sdl3-image",
      "features": [
        "png"
      ]
    },
    {
      "name": "sdl3-ttf",
      "features": [
        "svg"
      ]
    },
    "tinyxml2",
    "utfcpp",
    "zlib"
  ]
}
