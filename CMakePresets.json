{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "include": [
    "CMake/presets/base.json",
    "CMake/presets/windows.json",
    "CMake/presets/linux.json"
